# Freelancer Admin Chatbot - Example .env
# Copy this to .env and fill in your details

# --- LLM SWITCHES ---
USE_OPENAI=false
USE_GEMINI=true 

# --- GEMINI CONFIG (FREE CLOUD OPTION) ---
# Recommended for HF Spaces deployment
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash

# --- OPENAI CONFIG ---
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# --- LOCAL OLLAMA CONFIG ---
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2
LLM_API_KEY=ollama

# --- EMAIL CONFIG ---
GMAIL_SENDER=your_email@gmail.com
GMAIL_APP_PASS=your_app_password_here

# --- FLASK/DATABASE CONFIG ---
SECRET_KEY=your_secret_session_key_here
DATABASE_URL=sqlite:///data.db
FLASK_DEBUG=1
